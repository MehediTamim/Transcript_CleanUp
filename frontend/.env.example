# Preferred: backend origin (matches typical `uvicorn ... --port 8000`).
# Must be a URL, not the shell command. Loaded because vite.config uses envPrefix "AI_".
# AI_BASE_URL=http://127.0.0.1:8000
#
# Alternative (also supported):
# VITE_API_URL=http://127.0.0.1:8000
#
# If both are unset, dev server proxies /api (see vite.config.ts).
